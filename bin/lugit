			'user-list' => "\033[33mList repository users\033[0m\n\nUsage: lugit user-list <username> <repo-name>\n\nArguments:\n  username      Repository owner username\n  repo-name     Repository name\n\nExample:\n  lugit user-list alice my-project",

			'set-public' => "\033[33mMake repository public\033[0m\n\nUsage: lugit set-public <username> <name>\n\n\nMakes the repository publicly readable without authentication\n\nArguments:\n  username    Repository owner username\n  name        Repository name\n\nExample:\n  lugit set-public alice my-project",

			'set-private' => "\033[33mMake repository private\033[0m\n\nUsage: lugit set-private <username> <name>\n\n\nRestricts repository access to authorized users only\n\nArguments:\n  username    Repository owner username\n  name        Repository name\n\nExample:\n  lugit set-private alice my-project",

			'cicd-set' => "\033[33mInstall CI/CD hook\033[0m\n\nUsage: lugit cicd-set <username> <repo> <branch> <script>\n\nUploads a script to the server that runs automatically on push to the specified branch.\n\nArguments:\n  username    Repository owner username\n  repo        Repository name\n  branch      Branch name (e.g., main, develop)\n  script      Path to local script file\n\nExamples:\n  lugit cicd-set alice my-project main ./deploy.sh
  lugit cicd-set alice my-project develop ./test.sh",

			'cicd-del' => "\033[33mDelete CI/CD hook\033[0m\n\nUsage: lugit cicd-del <username> <repo> <branch>\n\nArguments:\n  username    Repository owner username\n  repo        Repository name\n  branch      Branch name\n\nExample:\n  lugit cicd-del alice my-project main",

			'cicd-list' => "\033[33mList CI/CD hooks\033[0m\n\nUsage: lugit cicd-list <username> <repo>\n\nArguments:\n  username    Repository owner username\n  repo        Repository name\n\nExample:\n  lugit cicd-list alice my-project",

			'cicd-logs' => "\033[33mShow CI/CD logs\033[0m\n\nUsage: lugit cicd-logs <username> <repo> <branch>\n\nArguments:\n  username    Repository owner username\n  repo        Repository name\n  branch      Branch name\n\nExample:\n  lugit cicd-logs alice my-project main",

			'cicd-logs-clean' => "\033[33mClear CI/CD logs\033[0m\n\nUsage: lugit cicd-logs-clean <username> <repo> <branch>\n\nArguments:\n  username    Repository owner username\n  repo        Repository name\n  branch      Branch name\n\nExample:\n  lugit cicd-logs-clean alice my-project main",

			'cicd-run' => "\033[33mRun CI/CD hook manually\033[0m\n\nUsage: lugit cicd-run <username> <repo> <branch>\n\n\nArguments:\n  username    Repository owner username\n  repo        Repository name\n  branch      Branch name\n\nExample:\n  lugit cicd-run alice my-project main",
		];

		if (isset($helps[$command])) {
			echo $helps[$command] . "\n";
		} else {
			self::printError("Unknown command: $command");
			exit(1);
		}
	}
}

Cli::run($argv);
#!/usr/bin/env php
<?php

namespace Lugit;

class Cli
{
	private static string $apiUrl = '';
	private static string $serverUrl = '';
	private static array $args = [];
	private static int $argIndex = 0;
	private static ?string $authFile = null;
	private static ?array $credentials = null;

	public static function run(array $argv): void
	{
		self::$authFile = getenv('HOME') . '/.lugit.json';
		self::loadCredentials();

		if (!isset($argv[1])) {
			self::printHelp();
			return;
		}

		$command = $argv[1];
		self::$args = array_slice($argv, 2);
		self::$argIndex = 0;

		if ($command === 'help' || $command === '--help' || $command === '-h') {
			if (isset(self::$args[0])) {
				self::printCommandHelp(self::$args[0]);
			} else {
				self::printHelp();
			}
			return;
		}

		if ($command === 'register') {
			self::cmdRegister();
			return;
		}

		if ($command === 'changepass') {
			self::cmdChangePassword();
			return;
		}

		if ($command === 'login') {
			self::cmdLogin();
			return;
		}

		if ($command === 'logout') {
			self::cmdLogout();
			return;
		}

		if ($command === 'whoami') {
			self::cmdWhoami();
			return;
		}

		if ($command === 'set-server') {
			self::cmdSetServer();
			return;
		}

		if (!self::isAuthenticated()) {
			self::printError("Not authenticated. Run 'lugit login <server-url> <username> <password>' first.");
			exit(1);
		}

		if ($command === 'cicd-set') {
			self::cmdCicdSet();
			return;
		}

		$handlers = [
			'list' => ['GET', '/repos', null, 'List all repositories'],
			'info' => ['GET', '/repos/{username}/{name}', ['username', 'name'], 'Show repository information'],
			'create' => ['POST', '/repos/{username}/{name}', ['username', 'name'], 'Create a new bare repository'],
			'delete' => ['DELETE', '/repos/{username}/{name}', ['username', 'name'], 'Delete a repository'],
			'user-add' => ['POST', '/repos/{username}/{name}/users/{targetUser}', ['username', 'name', 'targetUser'], 'Add user access to repository'],
			'user-remove' => ['DELETE', '/repos/{username}/{name}/users/{targetUser}', ['username', 'name', 'targetUser'], 'Remove user access from repository'],
			'user-list' => ['GET', '/repos/{username}/{name}/users', ['username', 'name'], 'List users with repository access'],
			'set-public' => ['PUT', '/repos/{username}/{name}/public', ['username', 'name'], 'Make repository public'],
			'set-private' => ['PUT', '/repos/{username}/{name}/private', ['username', 'name'], 'Make repository private'],
			'cicd-list' => ['GET', '/repos/{username}/{name}/cicd', ['username', 'name'], 'List CI/CD hooks for repository'],
			'cicd-del' => ['DELETE', '/repos/{username}/{name}/cicd/{branch}', ['username', 'name', 'branch'], 'Delete CI/CD hook'],
			'cicd-logs' => ['GET', '/repos/{username}/{name}/cicd/logs/{branch}', ['username', 'name', 'branch'], 'Show CI/CD logs for a branch'],
			'cicd-logs-clean' => ['DELETE', '/repos/{username}/{name}/cicd/logs/{branch}', ['username', 'name', 'branch'], 'Clear CI/CD logs for a branch'],
			'cicd-run' => ['POST', '/repos/{username}/{name}/cicd/{branch}/run', ['username', 'name', 'branch'], 'Manually run CI/CD hook'],
		];

		if (!isset($handlers[$command])) {
			self::printError("Unknown command: $command\nRun 'lugit help' for usage information.");
			exit(1);
		}

		try {
			[$method, $pathTemplate, $params, $description] = $handlers[$command];

			$path = $pathTemplate;
			$data = null;

			if (is_string($params)) {
				$value = self::argOrFail($params);
				$path = str_replace('{' . $params . '}', urlencode($value), $path);
			} elseif (is_array($params)) {
				foreach ($params as $param) {
					$value = self::argOrFail($param);
					$path = str_replace('{' . $param . '}', urlencode($value), $path);
				}
			}

			$response = self::request($method, $path, $data);

			self::formatOutput($command, $response);
		} catch (\Throwable $e) {
			self::printError($e->getMessage());
			exit(1);
		}
	}

	private static function loadCredentials(): void
	{
		if (file_exists(self::$authFile)) {
			$data = json_decode(file_get_contents(self::$authFile), true);
			if ($data && isset($data['username'], $data['password'], $data['server'])) {
				self::$credentials = $data;
				self::$serverUrl = rtrim($data['server'], '/');
				self::$apiUrl = self::$serverUrl . '/api/v1';
			}
		}
	}

	private static function saveCredentials(): void
	{
		file_put_contents(self::$authFile, json_encode(self::$credentials, JSON_PRETTY_PRINT));
		chmod(self::$authFile, 0600);
	}

	private static function isAuthenticated(): bool
	{
		if (self::$credentials === null || empty(self::$apiUrl)) {
			return false;
		}

		try {
			$response = self::request('GET', '/user');
			return isset($response['username']);
		} catch (\Throwable $e) {
			return false;
		}
	}

	private static function request(string $method, string $path, ?array $data = null): array
	{
		if (empty(self::$apiUrl)) {
			throw new \RuntimeException("Server URL not configured. Run 'lugit set-server <url>' first.");
		}

		$url = self::$apiUrl . $path;

		$ch = curl_init();
		curl_setopt($ch, CURLOPT_URL, $url);
		curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
		curl_setopt($ch, CURLOPT_TIMEOUT, 30);

		if (self::$credentials !== null && isset(self::$credentials['username'], self::$credentials['password'])) {
			curl_setopt($ch, CURLOPT_USERPWD, self::$credentials['username'] . ':' . self::$credentials['password']);
			curl_setopt($ch, CURLOPT_HTTPAUTH, CURLAUTH_BASIC);
		}

		if ($method !== 'GET') {
			curl_setopt($ch, CURLOPT_CUSTOMREQUEST, $method);
			if ($data !== null) {
				curl_setopt($ch, CURLOPT_POSTFIELDS, json_encode($data));
				curl_setopt($ch, CURLOPT_HTTPHEADER, ['Content-Type: application/json']);
			}
		}

		$response = curl_exec($ch);
		$httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
		$curlError = curl_error($ch);
		curl_close($ch);

		if ($curlError) {
			throw new \RuntimeException("Connection error: $curlError");
		}

		if ($httpCode === 401) {
			throw new \RuntimeException("Authentication failed. Please login again.");
		}

		if ($httpCode >= 400) {
			$result = json_decode($response, true);
			$errorMsg = $result['error'] ?? $result['message'] ?? "HTTP $httpCode";
			echo "Error: $errorMsg\n";
			exit(1);
		}

		$result = json_decode($response, true);
		if ($result === null && $response !== '') {
			throw new \RuntimeException("Invalid JSON response from server");
		}

		return $result ?? [];
	}

	private static function arg(): ?string
	{
		if (self::$argIndex >= count(self::$args)) {
			return null;
		}
		return self::$args[self::$argIndex++] ?? null;
	}

	private static function argOrFail(string $name): string
	{
		$arg = self::arg();
		if ($arg === null) {
			self::printError("Missing required argument: $name");
			exit(1);
		}
		return $arg;
	}

	private static function cmdChangePassword(): void
	{
		$newPassword = self::argOrFail('new-password');

		$serverUrl = self::$credentials['server'];

		$apiUrl = $serverUrl . '/api/v1';

		$ch = curl_init();
		curl_setopt($ch, CURLOPT_URL, $apiUrl . '/changepass');
		curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
		curl_setopt($ch, CURLOPT_POST, true);
		curl_setopt($ch, CURLOPT_POSTFIELDS, json_encode([
			'username' => self::$credentials['username'],
			'password' => self::$credentials['password'],
			'newPassword' => $newPassword
		]));
		curl_setopt($ch, CURLOPT_HTTPHEADER, ['Content-Type: application/json']);

		$response = curl_exec($ch);
		$httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
		curl_close($ch);

		if ($httpCode === 200) {
			self::printSuccess("Password changed successfully!");
			self::$credentials['password'] = $newPassword;
			self::saveCredentials();
		} elseif ($httpCode === 401) {
			self::printError("Invalid credentials");
		} else {
			$result = json_decode($response, true);
			$error = $result['error'] ?? "Password change failed (HTTP $httpCode)";
			self::printError($error);
		}
	}

	private static function cmdRegister(): void
	{
		$serverUrl = self::argOrFail('server-url');
		$username = self::argOrFail('username');
		$password = self::argOrFail('password');

		if (!filter_var($serverUrl, FILTER_VALIDATE_URL)) {
			self::printError("Invalid server URL format");
			exit(1);
		}

		$serverUrl = rtrim($serverUrl, '/');
		$apiUrl = $serverUrl . '/api/v1';

		$ch = curl_init();
		curl_setopt($ch, CURLOPT_URL, $apiUrl . '/register');
		curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
		curl_setopt($ch, CURLOPT_POST, true);
		curl_setopt($ch, CURLOPT_POSTFIELDS, json_encode([
			'username' => $username,
			'password' => $password
		]));
		curl_setopt($ch, CURLOPT_HTTPHEADER, ['Content-Type: application/json']);

		$response = curl_exec($ch);
		$httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
		curl_close($ch);

		if ($httpCode === 201 || $httpCode === 200) {
			self::printSuccess("User registered successfully!");

			self::$credentials = [
				'server' => self::$serverUrl,
				'username' => $username,
				'password' => $password
			];
			self::saveCredentials();
		} elseif ($httpCode === 409) {
			self::printError("User already exists");
		} else {
			$result = json_decode($response, true);
			$error = $result['error'] ?? "Registration failed (HTTP $httpCode)";
			self::printError($error);
		}
	}

	private static function cmdLogin(): void
	{
		$serverUrl = self::argOrFail('server-url');
		$username = self::argOrFail('username');
		$password = self::argOrFail('password');

		if (!filter_var($serverUrl, FILTER_VALIDATE_URL)) {
			self::printError("Invalid server URL format");
			exit(1);
		}

		self::$serverUrl = rtrim($serverUrl, '/');
		self::$apiUrl = self::$serverUrl . '/api/v1';
		self::$credentials = [
			'server' => self::$serverUrl,
			'username' => $username,
			'password' => $password
		];

		try {
			$response = self::request('GET', '/user');
			if ($response['username']) {
				self::saveCredentials();
				self::printSuccess("Logged in as: {$response['username']}");
				echo "Server: " . self::$serverUrl . "\n";
			} else {
				self::printError("Login failed: Invalid credentials");
				exit(1);
			}
		} catch (\Throwable $e) {
			self::$credentials = null;
			self::printError("Login failed: " . $e->getMessage());
			exit(1);
		}
	}

	private static function cmdLogout(): void
	{
		if (file_exists(self::$authFile)) {
			unlink(self::$authFile);
		}
		self::$credentials = null;
		self::$apiUrl = '';
		self::$serverUrl = '';
		self::printSuccess("Logged out successfully");
	}

	private static function cmdWhoami(): void
	{
		if (!self::isAuthenticated()) {
			echo "Not logged in\n";
			return;
		}

		try {
			$response = self::request('GET', '/user');
			echo "\n";
			echo "┌─────────────────────────────────────────\n";
			echo "│ Username: " . $response['username'] . "\n";
			echo "│ Server:   " . self::$serverUrl . "\n";
			echo "└─────────────────────────────────────────\n";
		} catch (\Throwable $e) {
			echo "Not logged in or connection failed\n";
		}
	}

	private static function cmdSetServer(): void
	{
		$url = self::argOrFail('server-url');

		if (!filter_var($url, FILTER_VALIDATE_URL)) {
			self::printError("Invalid URL");
			exit(1);
		}

		self::$serverUrl = rtrim($url, '/');
		self::$apiUrl = self::$serverUrl . '/api/v1';

		if (self::$credentials !== null) {
			self::$credentials['server'] = self::$serverUrl;
			self::saveCredentials();
		}

		self::printSuccess("Server URL set to: " . self::$serverUrl);
	}

	private static function cmdCicdSet(): void
	{
		$username = self::argOrFail('username');
		$repoName = self::argOrFail('repoName');
		$branchName = self::argOrFail('branchName');
		$scriptPath = self::argOrFail('scriptPath');

		if (!file_exists($scriptPath)) {
			self::printError("Script file not found: $scriptPath");
			exit(1);
		}

		$scriptContent = file_get_contents($scriptPath);
		$encoded = base64_encode($scriptContent);

		$path = '/repos/' . urlencode($username) . '/' . urlencode($repoName) . '/cicd/' . urlencode($branchName);
		$data = ['script' => $encoded];

		$response = self::request('POST', $path, $data);
		self::printSuccess("CI/CD hook installed for branch '$branchName' in '$repoName'");
	}

	private static function formatOutput(string $command, array $data): void
	{
		switch ($command) {
			case 'list':
				self::formatRepoList($data);
				break;
			case 'info':
				self::formatRepoInfo($data);
				break;
			case 'user-list':
				self::formatUserList($data);
				break;
			case 'create':
				self::printSuccess("Repository created successfully!");
				self::formatRepoInfo($data);
				break;
			case 'delete':
				self::printSuccess("Repository deleted successfully");
				break;
			case 'user-add':
				self::printSuccess("User added successfully");
				break;
			case 'user-remove':
				self::printSuccess("User removed successfully");
				break;
			case 'set-public':
				self::printSuccess("Repository is now public");
				break;
			case 'set-private':
				self::printSuccess("Repository is now private");
				break;
			case 'cicd-list':
				self::formatCicdList($data);
				break;
			case 'cicd-logs':
				self::formatCicdLogs($data);
				break;
			case 'cicd-logs-clean':
				self::printSuccess("CI/CD logs cleared successfully");
				break;
			case 'cicd-del':
				self::printSuccess("CI/CD hook deleted successfully");
				break;
			case 'cicd-run':
				self::printSuccess("CI/CD hook triggered manually");
				break;
			default:
				echo json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n";
		}
	}

	private static function formatRepoList(array $repos): void
	{
		if (empty($repos)) {
			echo "No repositories found.\n";
			return;
		}

		echo "\n";
		echo sprintf("┌%s┬%s┬%s┐\n", str_repeat('─', 15), str_repeat('─', 25), str_repeat('─', 12));
		echo sprintf("│ %-13s │ %-23s │ %-10s │\n", "Username", "Repository", "Visibility");
		echo sprintf("├%s┼%s┼%s┤\n", str_repeat('─', 15), str_repeat('─', 25), str_repeat('─', 12));

		foreach ($repos as $repo) {
			$username = substr($repo['username'] ?? 'Unknown', 0, 13);
			$name = substr($repo['name'] ?? 'Unknown', 0, 23);
			$visibility = ($repo['public'] ?? false) ? 'public' : 'private';
			echo sprintf("│ %-13s │ %-23s │ %-10s │\n", $username, $name, $visibility);
		}

		echo sprintf("└%s┴%s┴%s┘\n", str_repeat('─', 15), str_repeat('─', 25), str_repeat('─', 12));
		echo sprintf("\nTotal: %d repositories\n", count($repos));
	}

	private static function formatRepoInfo(array $repo): void
	{
		echo "\n";
		echo "╔══════════════════════════════════════════╗\n";
		echo "║ Repository Information                   ║\n";
		echo "╠══════════════════════════════════════════╣\n";
		echo "║ Username:  " . str_pad($repo['username'] ?? 'Unknown', 27) . "║\n";
		echo "║ Name:      " . str_pad($repo['name'] ?? 'Unknown', 27) . "║\n";
		echo "║ Visibility: " . str_pad(($repo['public'] ?? false) ? 'public' : 'private', 26) . "║\n";

		if (isset($repo['users']) && is_array($repo['users'])) {
			echo "╠══════════════════════════════════════════╣\n";
			echo "║ Users with access:                       ║\n";
			foreach ($repo['users'] as $user) {
				echo "║   • " . str_pad($user, 33) . "║\n";
			}
		}

		echo "╚══════════════════════════════════════════╝\n";

		if (isset($repo['username'], $repo['name'])) {
			echo "\n📦 Git URL: " . self::$serverUrl . "/" . $repo['username'] . "/" . $repo['name'] . "\n";
		}
	}

	private static function formatUserList(array $users): void
	{
		if (empty($users)) {
			echo "No users have access to this repository.\n";
			return;
		}

		echo "\n";
		echo "┌─────────────────────────────────────────┐\n";
		echo "│ Users with repository access            │\n";
		echo "├─────────────────────────────────────────┤\n";

		foreach ($users as $user) {
			$userName = is_array($user) ? ($user['username'] ?? 'Unknown') : $user;
			echo "│ • " . str_pad($userName, 37) . "│\n";
		}

		echo "└─────────────────────────────────────────┘\n";
		echo sprintf("\nTotal: %d users\n", count($users));
	}

	private static function formatCicdList(array $data): void
	{
		$hooks = $data['hooks'] ?? [];
		if (empty($hooks)) {
			echo "No CI/CD hooks installed.\n";
			return;
		}

		echo "\n";
		echo "┌─────────────────────────────────────────┐\n";
		echo "│ CI/CD Hooks                              │\n";
		echo "├─────────────────────────────────────────┤\n";

		foreach ($hooks as $hook) {
			echo "│ • " . str_pad($hook, 37) . "│\n";
		}

		echo "└─────────────────────────────────────────┘\n";
		echo sprintf("\nTotal: %d hook(s)\n", count($hooks));
	}

	private static function formatCicdLogs(array $data): void
	{
		$logs = $data['logs'] ?? [];
		if (empty($logs)) {
			echo "No CI/CD logs found.\n";
			return;
		}

		echo "\n";
		foreach ($logs as $branch => $content) {
			echo "╔══════════════════════════════════════════╗\n";
			echo "║ Branch: " . str_pad($branch, 32) . "║\n";
			echo "╚══════════════════════════════════════════╝\n";
			echo $content ?: "(empty)\n";
			echo "\n";
		}
	}

	private static function printSuccess(string $message): void
	{
		echo "\033[32m✓ " . $message . "\033[0m\n";
	}

	private static function printError(string $message): void
	{
		fwrite(STDERR, "\033[31m✗ Error: " . $message . "\033[0m\n");
	}

	private static function printHelp(): void
	{
		echo <<<HELP
\033[36m
╔══════════════════════════════════════════════════════════════╗
║                    Lugit - Git HTTP Server CLI              ║
╚══════════════════════════════════════════════════════════════╝
\033[0m

\033[33mUsage:\033[0m
    lugit <command> [arguments]

\033[33mAuthentication Commands:\033[0m
    login <server-url> <user> <pass>       Login to a git server
    register <server-url> <user> <pass>    Register a new user
    changepass <new-password>              Change current user password
    logout                                 Logout current user
    whoami                                 Show current user and server
    set-server <url>                       Set default server URL

\033[33mRepository Commands:\033[0m
    list                                   List all repositories
    info <user> <name>                     Show repository information
    create <user> <name>                    Create a new bare repository
    delete <user> <name>                    Delete a repository
    set-public <user> <name>                Make repository public
    set-private <user> <name>               Make repository private

\033[33mUser Management Commands:\033[0m
    user-add <user> <repo> <username>       Add user access to repository
    user-remove <user> <repo> <username>    Remove user access from repository
    user-list <user> <repo>                 List users with repository access

\033[33mCI/CD Commands:\033[0m
    cicd-set <user> <repo> <branch> <script>  Upload and install a CI/CD hook script
    cicd-del <user> <repo> <branch>          Delete a CI/CD hook
    cicd-list <user> <repo>                 List installed CI/CD hooks
    cicd-run <user> <repo> <branch>         Manually trigger a CI/CD hook
    cicd-logs <user> <repo> <branch>        Show CI/CD logs for a branch
    cicd-logs-clean <user> <repo> <branch>  Clear CI/CD logs for a branch

\033[33mOther Commands:\033[0m
    help [command]                          Show help for a command

\033[33mExamples:\033[0m
    lugit login http://localhost:8080 alice secret123
    lugit create alice my-project
    lugit list
    lugit user-add alice my-project bob
    lugit info alice my-project

\033[90mNote: Credentials are stored securely in ~/.lugit.json\033[0m

HELP;
	}

	private static function printCommandHelp(string $command): void
	{
		$helps = [
			'register' => "\033[33mRegister a new user account\033[0m\n\nUsage: lugit register <server-url> <username> <password>\n\nArguments:\n  server-url    Git server URL (e.g., http://localhost:8080)\n  username      Desired username\n  password      Desired password\n\nExample:\n  lugit register http://localhost:8080 alice mypass123",

			'login' => "\033[33mLogin to a git server\033[0m\n\nUsage: lugit login <server-url> <username> <password>\n\nArguments:\n  server-url    Git server URL\n  username      Your username\n  password      Your password\n\nExample:\n  lugit login http://localhost:8080 alice mypass123",
			'changepass' => "\033[33mChange current user password\033[0m\n\nUsage: lugit changepass <new-password>\n\nArguments:\n  new-password  New password\n\nExample:\n  lugit changepass newpass123",

			'logout' => "\033[33mLogout\033[0m\n\nUsage: lugit logout\n\nClears stored credentials from ~/.lugit.json",

			'whoami' => "\033[33mShow current user\033[0m\n\nUsage: lugit whoami\n\nDisplays currently logged in user and server information",

			'set-server' => "\033[33mSet default server\033[0m\n\nUsage: lugit set-server <url>\n\n\nArguments:\n  url    Default server URL\n\nExample:\n  lugit set-server http://localhost:8080",

			'list' => "\033[33mList repositories\033[0m\n\nUsage: lugit list\n\nShows all repositories you have access to in a formatted table",

			'info' => "\033[33mShow repository info\033[0m\n\nUsage: lugit info <username> <name>\n\n\nArguments:\n  username    Repository owner username\n  name        Repository name\n\nExample:\n  lugit info alice my-project",

			'create' => "\033[33mCreate repository\033[0m\n\nUsage: lugit create <username> <name>\n\n\nArguments:\n  username    Repository owner username\n  name        Repository name\n\nExample:\n  lugit create alice my-new-project",

			'delete' => "\033[33mDelete repository\033[0m\n\nUsage: lugit delete <username> <name>\n\n⚠️  This action cannot be undone!\n\nArguments:\n  username    Repository owner username\n  name        Repository name\n\nExample:\n  lugit delete alice old-project",

			'user-add' => "\033[33mAdd user to repository\033[0m\n\nUsage: lugit user-add <username> <repo-name> <target-user>\n\n\nArguments:\n  username      Repository owner username\n  repo-name     Repository name\n  target-user   Username to add\n\nExample:\n  lugit user-add alice my-project bob",

